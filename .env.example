# Copy to .env and adjust. GTM_ vars configure the app; ANTHROPIC_API_KEY is read as-is.
GTM_APP_NAME=AdLift — AI Campaign Optimizer
GTM_DEBUG=true

# Chatbot / generation brain: "stub" (default, no key) or "claude" (real LLM).
GTM_CHAT_BRAIN=stub
# Model used when GTM_CHAT_BRAIN=claude (sonnet = faster; opus = deeper).
GTM_ANTHROPIC_MODEL=claude-sonnet-5

# Required when GTM_CHAT_BRAIN=claude (or run `ant auth login`). Never commit a real key.
# ANTHROPIC_API_KEY=sk-ant-...

# Seed example campaigns on startup (when the store is empty).
GTM_SEED_EXAMPLES=true

# Path to the questionnaire definition (defaults to the bundled questions.yaml).
# GTM_QUESTIONNAIRE_PATH=./my_questions.yaml

# --- Google Ads (real integration; optional) --------------------------------
# Install the client:  uv sync --extra google
# GTM_GOOGLE_DEVELOPER_TOKEN=...
# GTM_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GTM_GOOGLE_CLIENT_SECRET=...
# GTM_GOOGLE_REFRESH_TOKEN=...            # or obtain via /integrations/google/oauth/start
# GTM_GOOGLE_CUSTOMER_ID=1234567890       # target account (digits only)
# GTM_GOOGLE_LOGIN_CUSTOMER_ID=1234567890 # MCC id, optional
# GTM_GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/integrations/google/oauth/callback
# SAFETY: publishing is OFF by default; enabling still creates PAUSED campaigns.
# GTM_GOOGLE_ALLOW_PUBLISH=false
